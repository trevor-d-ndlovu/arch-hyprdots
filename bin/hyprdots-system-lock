#!/bin/bash

# hyprdots:summary=Lock the computer and turn off the display
# hyprdots:group=system
# hyprdots:name=lock
# hyprdots:examples=hyprdots system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    hyprdots-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.hyprdots.screensaver

if [[ ${HYPRDOTS_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    hyprdots-brightness-keyboard off
    hyprdots-brightness-display off
  ) &
fi
