#!/bin/bash

# hyprdots:summary=Remove Moonlight and its configs and caches.
# hyprdots:requires-sudo=true

set -e

hyprdots-pkg-drop moonlight-qt

rm -rf \
  "$HOME/.config/Moonlight Game Streaming Project" \
  "$HOME/.cache/Moonlight Game Streaming Project"

echo ""
echo "Moonlight and its data have been removed."
