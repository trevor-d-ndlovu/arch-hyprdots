#!/bin/bash

# hyprdots:summary=Update Hyprdots and system packages
# hyprdots:args=[-y]
# hyprdots:examples=hyprdots update | hyprdots update -y
# hyprdots:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $HYPRDOTS_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env HYPRDOTS_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/hyprdots-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, open an issue at https://github.com/trevor-d-ndlovu/arch-hyprdots/issues\033[0m"' ERR

if [[ $1 == "-y" ]] || hyprdots-update-confirm; then
  hyprdots-snapshot create || (($? == 127))
  hyprdots-update-git
  hyprdots-update-perform
fi
