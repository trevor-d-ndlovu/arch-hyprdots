#!/bin/bash

# hyprdots:summary=Prompt for text input with Walker
# hyprdots:group=menu
# hyprdots:name=input
# hyprdots:args=prompt [walker args...]
# hyprdots:examples=hyprdots menu input Reminder|hyprdots-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

hyprdots-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
