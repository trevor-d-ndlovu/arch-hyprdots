#!/bin/bash

# hyprdots:summary=Set the branch for Hyprdots's git repository.
# hyprdots:args=<master|rc|dev>

if (($# == 0)); then
  echo "Usage: hyprdots-branch-set [master|rc|dev]"
  exit 1
else
  branch="$1"
fi

if [[ $branch != "master" && $branch != "rc" && $branch != "dev" ]]; then
  echo "Error: Invalid branch '$branch'. Must be one of: master, rc, dev"
  exit 1
fi

git -C $HYPRDOTS_PATH switch $branch
