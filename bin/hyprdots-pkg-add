#!/bin/bash

# hyprdots:summary=Install packages if missing (tries pacman first, then yay for AUR)
# hyprdots:args=<packages...>
# hyprdots:examples=hyprdots pkg add jq ripgrep
# hyprdots:requires-sudo=true

if ! hyprdots-pkg-missing "$@"; then
  exit 0
fi

# Separate pacman and AUR packages
pacman_pkgs=()
aur_pkgs=()

for pkg in "$@"; do
  if pacman -Si "$pkg" &>/dev/null 2>&1; then
    pacman_pkgs+=("$pkg")
  else
    aur_pkgs+=("$pkg")
  fi
done

# Install pacman packages
if ((${#pacman_pkgs[@]} > 0)); then
  sudo pacman -S --noconfirm --needed "${pacman_pkgs[@]}" || exit 1
fi

# Install AUR packages via yay
if ((${#aur_pkgs[@]} > 0)); then
  if ! command -v yay &>/dev/null; then
    echo "yay not found, can't install AUR packages: ${aur_pkgs[*]}" >&2
    exit 1
  fi
  yay -S --noconfirm --needed "${aur_pkgs[@]}" || exit 1
fi

# Verify all packages installed
for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
