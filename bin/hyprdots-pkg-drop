#!/bin/bash

# hyprdots:summary=Remove all the named packages from the system if they're installed (otherwise ignore).
# hyprdots:args=<packages...>
# hyprdots:requires-sudo=true

installed=()
for pkg in "$@"; do
  if pacman -Q "$pkg" &>/dev/null; then
    installed+=("$pkg")
  fi
done

if (( ${#installed[@]} > 0 )); then
  sudo pacman -Rns --noconfirm "${installed[@]}"
fi
