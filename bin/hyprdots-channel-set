#!/bin/bash

# hyprdots:summary=Set the Hyprdots channel, which dictates what git branch and package repository is used.
# hyprdots:args=<stable|rc|edge|dev>
# hyprdots:requires-sudo=true

if (($# == 0)); then
  echo "Usage: hyprdots-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") hyprdots-branch-set "master" && hyprdots-refresh-pacman "stable" ;;
"rc") hyprdots-branch-set "rc" && hyprdots-refresh-pacman "rc" ;;
"edge") hyprdots-branch-set "master" && hyprdots-refresh-pacman "edge" ;;
"dev") hyprdots-branch-set "dev" && hyprdots-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

hyprdots-update -y
