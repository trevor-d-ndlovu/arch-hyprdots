#!/bin/bash

# hyprdots:summary=Shut down after closing application windows
# hyprdots:examples=hyprdots shutdown | hyprdots system shutdown
# hyprdots:aliases=hyprdots shutdown

hyprdots-state clear re*-required

# Schedule the shutdown to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl poweroff --no-wall" >/dev/null 2>&1 &

# Now close all windows
hyprdots-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
