#!/bin/bash

# hyprdots:summary=Launch or focus on a given web app identified by the window-pattern.
# hyprdots:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: hyprdots-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="hyprdots-launch-webapp $@"

exec hyprdots-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
