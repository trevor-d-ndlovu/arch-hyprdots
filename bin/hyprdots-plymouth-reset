#!/bin/bash

# hyprdots:summary=Restore the default Hyprdots Plymouth boot theme and SDDM login screen
# hyprdots:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/hyprdots"

sudo find ~/.local/share/hyprdots/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme hyprdots

if hyprdots-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

hyprdots-refresh-sddm
