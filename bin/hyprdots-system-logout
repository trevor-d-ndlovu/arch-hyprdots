#!/bin/bash

# hyprdots:summary=Log out after closing application windows
# hyprdots:examples=hyprdots logout | hyprdots system logout
# hyprdots:aliases=hyprdots logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
hyprdots-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
