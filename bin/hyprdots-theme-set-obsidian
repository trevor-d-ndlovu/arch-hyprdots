#!/bin/bash

# hyprdots:summary=Sync Hyprdots theme to all Obsidian vaults
# hyprdots:hidden=true

CURRENT_THEME_DIR="$HOME/.config/hyprdots/current/theme"

[[ -f $CURRENT_THEME_DIR/obsidian.css ]] || exit 0

jq -r '.vaults | values[].path' ~/.config/obsidian/obsidian.json 2>/dev/null | while read -r vault_path; do
  [[ -d $vault_path/.obsidian ]] || continue

  theme_dir="$vault_path/.obsidian/themes/Hyprdots"
  mkdir -p "$theme_dir"

  [[ -f $theme_dir/manifest.json ]] || cat >"$theme_dir/manifest.json" <<'EOF'
{
  "name": "Hyprdots",
  "version": "1.0.0",
  "minAppVersion": "0.16.0",
  "description": "Automatically syncs with your current Hyprdots system theme colors and fonts",
  "author": "Hyprdots",
  "authorUrl": "https://hyprdots.org"
}
EOF

  cp "$CURRENT_THEME_DIR/obsidian.css" "$theme_dir/theme.css"
done
