#!/bin/bash

# hyprdots:summary=Install the NordVPN service with optional GUI.
# hyprdots:requires-sudo=true

echo "Installing NordVPN..."
hyprdots-pkg-aur-add nordvpn-bin

echo "Enabling NordVPN daemon..."
sudo systemctl enable --now nordvpnd

echo "Adding user to nordvpn group..."
sudo usermod -aG nordvpn "$USER"

echo -e "\nNordVPN installed! After reboot, run 'nordvpn login' to authenticate."

echo
gum confirm "Reboot now to make NordVPN usable?" && hyprdots-system-reboot
