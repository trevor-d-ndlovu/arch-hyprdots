#!/bin/bash

# hyprdots:summary=Set or toggle shape of Hyprland window corners
# hyprdots:args=[toggle|sharp|round]
# hyprdots:examples=hyprdots style corners hyprland toggle | hyprdots style corners hyprland round | hyprdots style corners hyprland sharp

case "${1:-toggle}" in
  round) set -- on ;;
  sharp) set -- off ;;
  toggle) ;;
  *)
    echo "Usage: hyprdots-style-corners-hyprland [toggle|sharp|round]"
    exit 1
    ;;
esac

hyprdots-hyprland-toggle rounded-corners "$1"
