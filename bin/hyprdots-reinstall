#!/bin/bash

# hyprdots:summary=Reinstall Hyprdots packages and reset default configs
# hyprdots:requires-sudo=true

set -e

# Attempt to reinstall all default Hyprdots packages and reset all the default configs.

echo -e "This will reinstall all the default Hyprdots packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  hyprdots-reinstall-git
  hyprdots-reinstall-pkgs
  hyprdots-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && hyprdots-system-reboot
fi
