#!/bin/bash

# hyprdots:summary=Open HEY webmail and translate mailto links
# hyprdots:args=[url]

url="$1"
web_url="https://app.hey.com"

# Handle mailto: URLs
if [[ $url =~ ^mailto: ]]; then
  email=$(echo "$url" | sed 's/mailto://')
  web_url="https://app.hey.com/messages/new?to=$email"
fi

exec hyprdots-launch-webapp "$web_url"
