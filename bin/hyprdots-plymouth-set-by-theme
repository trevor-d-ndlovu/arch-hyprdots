#!/bin/bash

# hyprdots:summary=Set the Plymouth boot theme from an Hyprdots theme
# hyprdots:args=<theme-name>
# hyprdots:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via hyprdots-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: hyprdots-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/hyprdots/themes/$theme ]]; then
  theme_dir=~/.config/hyprdots/themes/$theme
else
  theme_dir="$HYPRDOTS_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec hyprdots-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
