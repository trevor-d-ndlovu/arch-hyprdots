#!/bin/bash

# hyprdots:summary=Display brightness level using SwayOSD on the current monitor.
# hyprdots:args=<0-100>
# hyprdots:examples=hyprdots swayosd brightness 0 | hyprdots swayosd brightness 50 | hyprdots swayosd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

hyprdots-swayosd-client \
  --custom-icon display-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "$(printf '%3d%%' "$percent")"
