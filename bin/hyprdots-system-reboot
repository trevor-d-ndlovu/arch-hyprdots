#!/bin/bash

# hyprdots:summary=Reboot after closing application windows
# hyprdots:examples=hyprdots reboot | hyprdots system reboot
# hyprdots:aliases=hyprdots reboot

hyprdots-state clear re*-required

# Schedule the reboot to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl reboot --no-wall" >/dev/null 2>&1 &

# Now close all windows
hyprdots-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
