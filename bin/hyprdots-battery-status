#!/bin/bash

# hyprdots:summary=Returns a formatted battery status string with percentage and power draw/charge.

battery_info=$(upower -i $(upower -e | grep BAT))

percentage=$(echo "$battery_info" | awk '/percentage/ {
    print int($2)
    exit
}')

power_rate=$(echo "$battery_info" | awk '/energy-rate/ {
    rounded = sprintf("%.1f", $2)
    sub(/¥.0$/, "", rounded)
    print rounded
    exit
}')

state=$(echo "$battery_info" | awk '/state/ { print $2; exit }')
time_remaining=$(hyprdots-battery-remaining-time)
capacity=$(hyprdots-battery-capacity)

if [[ $state == "charging" ]]; then
    echo "Battery ${percentage}%  ﾂｷ  ${time_remaining} to full  ﾂｷ  雒｢ ${power_rate}W / ${capacity}Wh"
else
    echo "Battery ${percentage}%  ﾂｷ  ${time_remaining} left  ﾂｷ  雒｣ ${power_rate}W / ${capacity}Wh"
fi
