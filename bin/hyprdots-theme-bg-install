#!/bin/bash

# hyprdots:summary=Open the current theme's user background folder

CURRENT_THEME_NAME=$(cat "$HOME/.config/hyprdots/current/theme.name")
THEME_USER_BACKGROUNDS="$HOME/.config/hyprdots/backgrounds/$CURRENT_THEME_NAME"

mkdir -p "$THEME_USER_BACKGROUNDS"
nautilus "$THEME_USER_BACKGROUNDS"
