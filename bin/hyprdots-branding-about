#!/bin/bash

# hyprdots:summary=Edit, set, or reset About branding
# hyprdots:group=branding
# hyprdots:name=about
# hyprdots:args=<image|text|reset>
# hyprdots:examples=hyprdots branding about image | hyprdots branding about text | hyprdots branding about reset

set -euo pipefail

SOURCE_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}"

case "${1:-}" in
image)
  image=$(hyprdots-menu-file "Pick png/svg from $SOURCE_DIR" "${SOURCE_DIR}" "svg png")
  if [[ -n $image ]] && hyprdots-transcode-ascii "$image" ~/.config/hyprdots/branding/about.txt --width 54 --height 26; then
    hyprdots-launch-about >/dev/null 2>&1
  fi
  ;;
text)
  hyprdots-launch-editor ~/.config/hyprdots/branding/about.txt >/dev/null 2>&1 && hyprdots-launch-about >/dev/null 2>&1
  ;;
reset)
  cp "$HYPRDOTS_PATH/icon.txt" ~/.config/hyprdots/branding/about.txt && hyprdots-launch-about >/dev/null 2>&1
  ;;
*)
  echo "Usage: hyprdots-branding-about <image|text|reset>" >&2
  exit 1
  ;;
esac
