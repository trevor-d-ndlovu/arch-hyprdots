#!/bin/bash

# hyprdots:summary=Apply an Hyprdots theme
# hyprdots:args=<theme-name>
# hyprdots:examples=hyprdots theme list | hyprdots theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: hyprdots-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/hyprdots/current/theme"
NEXT_THEME_PATH="$HOME/.config/hyprdots/current/next-theme"
USER_THEMES_PATH="$HOME/.config/hyprdots/themes"
HYPRDOTS_THEMES_PATH="$HYPRDOTS_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $HYPRDOTS_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$HYPRDOTS_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  hyprdots-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
hyprdots-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/hyprdots/current/theme.name"

# Change background with theme
if [[ $HYPRDOTS_THEME_SKIP_BACKGROUND != "1" ]]; then
  hyprdots-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  hyprdots-restart-waybar
fi
hyprdots-restart-swayosd
hyprdots-restart-terminal
hyprdots-restart-hyprctl
hyprdots-restart-btop
hyprdots-restart-opencode
hyprdots-restart-mako
hyprdots-restart-helix

# Change app-specific themes
hyprdots-theme-set-foot
hyprdots-theme-set-gnome
hyprdots-theme-set-browser
hyprdots-theme-set-vscode
hyprdots-theme-set-obsidian
hyprdots-theme-set-keyboard

# Call hook on theme set
hyprdots-hook theme-set "$THEME_NAME" >/dev/null

# Warm the background selector cache after the theme is applied, off the critical path.
hyprdots-theme-bg-cache >/dev/null 2>&1 &
