#!/bin/bash

# hyprdots:summary=Reinstall all default Hyprdots packages from the stable channel
# hyprdots:requires-sudo=true

set -e

# Reinstall all default Hyprdots packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
hyprdots-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$HYPRDOTS_PATH/install/hyprdots-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
